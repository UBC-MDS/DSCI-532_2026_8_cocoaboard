<svg width="100%" viewBox="0 0 680 520">
<defs>
  <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></marker>
</defs>

<!-- Title bar -->
<g class="c-coral">
  <rect x="20" y="10" width="640" height="40" rx="8" stroke-width="0.5"/>
  <text class="th" x="40" y="26" dominant-baseline="central">CocoaBoard</text>
  <text class="ts" x="40" y="40" dominant-baseline="central">Explore global chocolate sales by country, product, and sales rep</text>
</g>

<!-- Sidebar -->
<g class="c-gray">
  <rect x="20" y="60" width="140" height="340" rx="8" stroke-width="0.5"/>
  <text class="th" x="90" y="82" text-anchor="middle" dominant-baseline="central">Filters</text>
</g>
<text class="ts" x="90" y="106" text-anchor="middle">Year buttons</text>
<rect x="36" y="96" width="108" height="18" rx="4" fill="none" stroke="var(--b)" stroke-width="0.5"/>
<text class="ts" x="90" y="136" text-anchor="middle">Date range</text>
<rect x="36" y="126" width="108" height="18" rx="4" fill="none" stroke="var(--b)" stroke-width="0.5"/>
<text class="ts" x="90" y="166" text-anchor="middle">Country (multi)</text>
<rect x="36" y="156" width="108" height="18" rx="4" fill="none" stroke="var(--b)" stroke-width="0.5"/>
<text class="ts" x="90" y="196" text-anchor="middle">Product (multi)</text>
<rect x="36" y="186" width="108" height="18" rx="4" fill="none" stroke="var(--b)" stroke-width="0.5"/>
<g class="c-gray">
  <rect x="36" y="216" width="108" height="24" rx="4" stroke-width="0.5"/>
  <text class="ts" x="90" y="228" text-anchor="middle" dominant-baseline="central">Clear selections</text>
</g>
<g class="c-gray">
  <rect x="36" y="248" width="108" height="24" rx="4" stroke-width="0.5"/>
  <text class="ts" x="90" y="260" text-anchor="middle" dominant-baseline="central">Reset filters</text>
</g>

<!-- KPI row 1 -->
<g class="c-teal">
  <rect x="172" y="60" width="118" height="52" rx="6" stroke-width="0.5"/>
  <text class="th" x="231" y="78" text-anchor="middle" dominant-baseline="central">Total revenue</text>
  <text class="ts" x="231" y="96" text-anchor="middle" dominant-baseline="central">$1,234,567</text>
</g>
<g class="c-teal">
  <rect x="298" y="60" width="118" height="52" rx="6" stroke-width="0.5"/>
  <text class="th" x="357" y="78" text-anchor="middle" dominant-baseline="central">Avg revenue</text>
  <text class="ts" x="357" y="96" text-anchor="middle" dominant-baseline="central">$4,567</text>
</g>
<g class="c-teal">
  <rect x="424" y="60" width="114" height="52" rx="6" stroke-width="0.5"/>
  <text class="th" x="481" y="78" text-anchor="middle" dominant-baseline="central">YoY revenue</text>
  <text class="ts" x="481" y="96" text-anchor="middle" dominant-baseline="central">+12.3%</text>
</g>
<g class="c-teal">
  <rect x="546" y="60" width="114" height="52" rx="6" stroke-width="0.5"/>
  <text class="th" x="603" y="78" text-anchor="middle" dominant-baseline="central">MoM revenue</text>
  <text class="ts" x="603" y="96" text-anchor="middle" dominant-baseline="central">+5.1%</text>
</g>

<!-- KPI row 2 -->
<g class="c-teal">
  <rect x="172" y="120" width="118" height="52" rx="6" stroke-width="0.5"/>
  <text class="th" x="231" y="138" text-anchor="middle" dominant-baseline="central">Top product</text>
  <text class="ts" x="231" y="156" text-anchor="middle" dominant-baseline="central">Dark Bars 32%</text>
</g>
<g class="c-teal">
  <rect x="298" y="120" width="118" height="52" rx="6" stroke-width="0.5"/>
  <text class="th" x="357" y="138" text-anchor="middle" dominant-baseline="central">Top country</text>
  <text class="ts" x="357" y="156" text-anchor="middle" dominant-baseline="central">Australia 28%</text>
</g>

<!-- Revenue by Product -->
<g class="c-purple">
  <rect x="424" y="120" width="236" height="134" rx="8" stroke-width="0.5"/>
  <text class="th" x="542" y="140" text-anchor="middle" dominant-baseline="central">Revenue by product</text>
</g>
<rect x="444" y="156" width="140" height="10" rx="3" fill="#E63946" opacity="0.7"/>
<rect x="444" y="172" width="110" height="10" rx="3" fill="#457B9D" opacity="0.7"/>
<rect x="444" y="188" width="90" height="10" rx="3" fill="#2A9D8F" opacity="0.7"/>
<rect x="444" y="204" width="70" height="10" rx="3" fill="#E9C46A" opacity="0.7"/>
<rect x="444" y="220" width="50" height="10" rx="3" fill="#9B59B6" opacity="0.7"/>

<!-- Sales by Country (clickable map) -->
<g class="c-blue">
  <rect x="172" y="180" width="244" height="160" rx="8" stroke-width="0.5"/>
  <text class="th" x="294" y="200" text-anchor="middle" dominant-baseline="central">Sales by country (click to filter)</text>
</g>
<ellipse cx="250" cy="270" rx="40" ry="25" fill="#F4A261" opacity="0.5" stroke="var(--b)" stroke-width="0.3"/>
<ellipse cx="330" cy="255" rx="30" ry="20" fill="#E76F51" opacity="0.7" stroke="var(--b)" stroke-width="0.3"/>
<ellipse cx="365" cy="280" rx="25" ry="18" fill="#F4A261" opacity="0.4" stroke="var(--b)" stroke-width="0.3"/>
<ellipse cx="290" cy="300" rx="20" ry="12" fill="#2A9D8F" opacity="0.4" stroke="var(--b)" stroke-width="0.3"/>
<text class="ts" x="294" y="330" text-anchor="middle">Click country → toggles sidebar filter</text>

<!-- Map click arrow back to sidebar -->
<path d="M172 290 L155 290 L155 172" fill="none" class="arr" marker-end="url(#arrow)" stroke-dasharray="4 3"/>
<text class="ts" x="112" y="306" text-anchor="end">Toggles</text>
<text class="ts" x="112" y="318" text-anchor="end">filter</text>

<!-- Revenue trend -->
<g class="c-blue">
  <rect x="424" y="262" width="236" height="138" rx="8" stroke-width="0.5"/>
  <text class="th" x="542" y="282" text-anchor="middle" dominant-baseline="central">Revenue trend — top 5 reps</text>
</g>
<polyline points="444,370 474,355 504,360 534,340 564,348 594,325 624,335" fill="none" stroke="#E63946" stroke-width="1.5" opacity="0.8"/>
<polyline points="444,375 474,368 504,372 534,358 564,362 594,350 624,355" fill="none" stroke="#1D8CD6" stroke-width="1.5" opacity="0.7"/>
<polyline points="444,380 474,376 504,378 534,370 564,374 594,365 624,370" fill="none" stroke="#2ECC71" stroke-width="1.5" opacity="0.6"/>

<!-- Leaderboard -->
<g class="c-gray">
  <rect x="172" y="408" width="488" height="64" rx="8" stroke-width="0.5"/>
  <text class="th" x="416" y="428" text-anchor="middle" dominant-baseline="central">Sales rep leaderboard</text>
  <text class="ts" x="416" y="446" text-anchor="middle" dominant-baseline="central">Rank | Sales Rep | Revenue | Transactions | Boxes | Avg Deal | Rev Share %</text>
  <text class="ts" x="416" y="462" text-anchor="middle" dominant-baseline="central">+ AVERAGE / TOTAL summary row</text>
</g>

<!-- Footer -->
<text class="ts" x="340" y="500" text-anchor="middle">CocoaBoard | Daisy Zhou, Vinay Valson, Eduardo Rivera | GitHub</text>
</svg>